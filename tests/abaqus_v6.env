#
# Sample Abaqus environment file for Abaqus 2016 or newer.
#

import sys
import os


# On some systems, analyses will hang during the packager. The symptoms are as follows. The packager starts (indicated in the .log file),
# but the analysis does not proceed to the solver (explicit_dp). The header lines are printed in the .sta file, but no increment 
# information is printed. Abaqus tokens are checked out.
# The following line has been found to resolve the issus in many cases.
os.environ['MPI_FLUSH_FCACHE']='100'

# After you have compiled the library, you will need to set the following variable to the directory where the compiled library is located.
# usub_lib_dir = "PATH_TO_COMPILED_LIBRARY"

#
# The following are required for compiling; if you compile into a shared library, you will need the following lines
# for the abaqus make library=CompDam_DGD commmand, but they are not needed for subsequent analyses using the compiled library.
if sys.platform.startswith('linux'):

    compile_fortran = ['ifort', '-free', '-DABQ_LNX86_64',
                       '-mkl=sequential',   # Around intel 2021, this option is renamed to "-qmkl=sequential". The old option "-mkl" is still supported, but it will print a deprecation warning.
                       '-axCORE-AVX2', '-xSSE3',
                       '-V', '-c', '-fPIC', '-auto', '-mP2OPT_hpo_vec_divbyzero=F', '-extend-source',
                       '-fpp', '-WB', '-I%I']

elif sys.platform == 'win32':

    compile_fortran = ['ifort', '/free', '/Qmkl:sequential',
                       '/c','/DABQ_WIN86_64', '/extend-source', '/fpp',
                       '/iface:cref', '/recursive', '/Qauto-scalar',
                       '/QxSSE3', '/QaxAVX',
                       '/heap-arrays:1',
                       '/Od', '/Ob0',  # <-- Optimization Debugging
                       # '/Zi',          # <-- Debugging
                       #'/gen-interfaces', '/warn:interfaces', '/check', '/check:noarg_temp_created', '/fpe:0', # <-- Debugging
                       '/include:%I']

# Abaqus verbose logging
# Same as including `verbose=3` when submitting a job
# Only needed for debugging
#os.environ['ABA_VERBOSE'] = 3
