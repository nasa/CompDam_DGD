*Heading
 Single element test for characteristic element length calculations
**
*Parameter
** Inputs parameters
 alpha = 1.0
**
 length2 = 0.2
 length1 = length2 * alpha
 length3 = 0.1
 displacement = 0.0
 stepDuration = 5.e-7
** Material definition
 feature_flags = 0
 mu = 0
 density = 1.57e-09
 thickness = 0
**
 fiber_angle = 0.0
 misalignment_angle = 0.0
 skew_angle = 0.0
**
** Dependent parameters and constants
 Pi = 2.0 * acos(0.0)
 skew_1 = max(1e-9, length2 * sin(Pi * skew_angle / 180.0))
 skew_2 = max(1e-9, length2 * (1.0 - cos(Pi * skew_angle / 180.0)))
