200000, , 0., , 1.d7, 0.2, 0.95, 0.0,
, , , , , <YT_brdg>, <SL_brdg>, <GIc_brdg>,
<GIIc_brdg>, <BK_eta_brdg>, <YC>, <alpha0>, <K1_brdg>, , , ,
